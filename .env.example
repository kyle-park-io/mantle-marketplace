# GitHub Personal Access Token (prevents API rate limiting during sync)
GITHUB_TOKEN=

# GitHub Personal Access Token for MCP plugin
# Required for the github plugin (MCP server authentication)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=

# GitHub Personal Access Token for syncing external repos (mantle-xyz/*)
# Requires repo:read scope. The built-in GITHUB_TOKEN cannot access external repos.
MARKETPLACE_GITHUB_TOKEN=
